{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "GRAPHRAG_ROOT/opencode/instructions.md"
  ],
  "mcp": {
    "graphrag": {
      "type": "local",
      "command": ["python", "-m", "graph.mcp_server"],
      "cwd": "GRAPHRAG_ROOT",
      "enabled": true
    }
  },
  "plugin": [
    "GRAPHRAG_ROOT/opencode/plugins/memory.ts"
  ],
  "permission": {
    "mcp__graphrag__*": "allow"
  }
}
