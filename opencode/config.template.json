{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/codecompass/instructions.md"
  ],
  "mcp": {
    "codecompass": {
      "type": "local",
      "command": ["codecompass-mcp"],
      "enabled": true
    }
  },
  "plugin": [
    "~/.config/opencode/codecompass/plugins/memory.ts"
  ],
  "permission": {
    "mcp__codecompass__*": "allow"
  }
}
