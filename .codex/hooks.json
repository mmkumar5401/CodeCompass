{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "REPO=$(git rev-parse --show-toplevel 2>/dev/null || pwd) && python \"$REPO/scripts/on_file_change.py\" --project codecompass --root \"$REPO\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/scripts/on_compact.py\"",
            "timeout": 15,
            "statusMessage": "Saving learnings before compaction..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)/scripts/session_start.py\"",
            "timeout": 10,
            "statusMessage": "Loading project memory..."
          }
        ]
      }
    ]
  }
}
